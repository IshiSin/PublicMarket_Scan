# Upstash Redis (free tier at upstash.com)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# Python backend URL (local dev or Render/Fly.io deployment)
PYTHON_BACKEND_URL=http://localhost:8000

# Anthropic API key (for AI summary extraction)
ANTHROPIC_API_KEY=sk-ant-...

# Admin page password (single shared password)
ADMIN_PASSWORD=your_secure_password_here

# GitHub token + repo (for admin page to commit transcript files)
# Token needs: contents:write permission
GITHUB_TOKEN=ghp_...
GITHUB_REPO=owner/repo-name

# Public base URL (for server-side self-calls if needed)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Backend CORS allowed origins (comma-separated, defaults to localhost:3000)
ALLOWED_ORIGINS=http://localhost:3000,https://your-vercel-app.vercel.app
